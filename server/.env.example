# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Configuration (Optional - app works with file storage)
MONGODB_URI=mongodb://localhost:27017/nagar-setu
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/nagar-setu

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_REFRESH_EXPIRE=30d

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@nagarsetu.com
FROM_NAME=Nagar Setu

# Google Maps API (Optional)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,video/mp4

# AI Service Configuration
AI_SERVICE_URL=http://localhost:8000
